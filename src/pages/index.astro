			id="sidebar"
			class="fixed left-0 top-0 w-[82%] max-w-[340px] md:max-w-none md:w-full h-screen flex flex-col justify-between items-start p-10 md:p-20 lg:p-30 overflow-hidden z-30 md:z-10 bg-neutral-800/95 md:bg-transparent backdrop-blur-sm md:backdrop-blur-none -translate-x-full md:translate-x-0 transition-transform duration-300"
		>
			<button
				id="menuClose"
				class="md:hidden absolute top-5 right-5 text-neutral-300"
				aria-label="Fechar menu"
			>
				<span class="material-symbols-outlined">close</span>
			</button>

			<div class="w-full overflow-hidden">
