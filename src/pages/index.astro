			<div
				class="mt-5 w-full text-white justify-start items-start flex flex-col gap-5"
			>
				<ul
					class="w-full justify-start items-start flex flex-col gap-5"
				>
					<a class="normal" id="navsobre" href="#sobre">
						Sobre
						<div></div>
					</a>
					<a class="normal" id="navexperiencia" href="#experiencia">
						Experiência Profissional
						<div></div>
					</a>
					<a class="normal" id="navprojetos" href="#projetos">
						Principais Projetos
						<div></div>
					</a>
					<a class="normal" id="navtecnologias" href="#tecnologias">
						Principais Técnologias
