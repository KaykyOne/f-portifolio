---
import "../global.css";
---

<html lang="pt-br">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Kayky Zioti</title>
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined"
		/>
	</head>
	<body
		class="bg-neutral-800 w-full h-screen items-center justify-center overflow-auto grid grid-cols-1 md:grid-cols-2"
		id="container"
	>
		<button
			id="menuToggle"
			class="md:hidden fixed top-5 left-5 z-30 p-2 rounded-md bg-neutral-700/80 text-white"
			aria-label="Abrir menu"
		>
			<span class="material-symbols-outlined">menu</span>
		</button>

		<div
			id="menuOverlay"
			class="md:hidden fixed inset-0 bg-black/50 z-20 opacity-0 pointer-events-none transition-opacity duration-300"
		>
		</div>

		<div
			class="h-[40vh] w-[40vh] fixed bg-neutral-700 opacity-80 rounded-full blur-[150px] z-0 pointer-events-none"
			id="bolha"
		>
		</div>

		<div class="hidden md:block"></div>

		<!-- Navegação -->
		<div
			id="sidebar"
			class="fixed left-0 top-0 w-[82%] max-w-[340px] md:max-w-none md:w-full h-screen flex flex-col justify-between items-start p-10 md:p-20 lg:p-30 overflow-hidden z-30 md:z-10 bg-neutral-800/95 md:bg-transparent backdrop-blur-sm md:backdrop-blur-none -translate-x-full md:translate-x-0 transition-transform duration-300"
		>
			<button
				id="menuClose"
				class="md:hidden absolute top-5 right-5 text-neutral-300"
				aria-label="Fechar menu"
			>
				<span class="material-symbols-outlined">close</span>
			</button>

			<div>
				<div class="w-full overflow-hidden">
					<h1 class="text-4xl text-white font-bold">
						Kayky Zioti Silva
					</h1>
					<p
						class="text-white uppercase leading-10 text-sm font-light tracking-widest opacity-70"
					>
						Desenvolvedor Full-Stack
					</p>
					<p
						class="text-sm text-justify w-full text-neutral-400 font-light mt-5"
					>
						Full-stack Developer | Performance, UXUI & Lead
						Generation Systems
					</p>
				</div>

				<div
					class="mt-10 w-full text-white justify-start items-start flex flex-col gap-5"
				>
					<ul
						class="w-full justify-start items-start flex flex-col gap-5"
					>
						<a class="normal" id="navsobre" href="#sobre">
							Sobre
							<div></div>
						</a>
						<a
							class="normal"
							id="navexperiencia"
							href="#experiencia"
						>
							Experiência Profissional
							<div></div>
						</a>
						<a class="normal" id="navskills" href="#skills">
							Expertise Técnica
							<div></div>
						</a>
						<a class="normal" id="navprojetos" href="#projetos">
							Principais Projetos
							<div></div>
						</a>
					</ul>
				</div>
			</div>
			<div class="flex justify-start items-start gap-4 mt-5">
				<a
					href="https://www.linkedin.com/in/kaykyzioti/"
					target="_blank"
					class="h-8 w-8 opacity-40 hover:opacity-100 transition-opacity duration-300"
				>
					<img src="/linkedin.png" />
				</a>
				<a
					href="https://github.com/KaykyOne"
					target="_blank"
					class="h-8 w-8 opacity-40 hover:opacity-100 transition-opacity duration-300"
				>
					<img src="/github.png" />
				</a>
				<a
					href="https://www.instagram.com/kaykyzioti/"
					target="_blank"
					class="h-8 w-8 opacity-40 hover:opacity-100 transition-opacity duration-300"
				>
					<img src="/instagram.png" />
				</a>
			</div>
		</div>

		<!-- Conteúdo Principal -->
		<div
			class="w-full h-full flex flex-col items-start p-10 pt-24 md:pt-20 lg:pt-30 pr-10 md:pr-20 lg:pr-30 gap-4 text-white z-10 overflow-y-auto"
			id="conteudo"
		>
			<h1 class="text-white text-2xl font-semibold" id="sobre">.Sobre</h1>
			<div class="flex flex-col gap-4 max-w-xl">
				<p class="opacity-70 font-light text-justify">
					Sou Kayky Zioti, desenvolvedor full-stack com foco em criar 
					soluções web escaláveis, rápidas e com excelente UX/UI. 
					Especialista em arquitetura moderna, otimização de performance 
					e automação com IA.
				</p>
				<p class="opacity-70 font-light text-justify text-sm">
					<strong class="text-emerald-400">Meu diferencial:</strong> Combino 
					desenvolvimento técnico sólido com visão de negócio. Consigo entender 
					o que o cliente realmente precisa e transformar isso em produtos que 
					geram resultados mensuráveis.
				</p>
				<div class="flex flex-col gap-2 mt-4">
					<div class="flex gap-2">
						<span class="text-emerald-400">✓</span>
						<span class="text-sm">Full-Stack: Frontend, Backend, Database, DevOps</span>
					</div>
					<div class="flex gap-2">
						<span class="text-emerald-400">✓</span>
						<span class="text-sm">Sistemas em Produção: +200 usuários ativos diários</span>
					</div>
					<div class="flex gap-2">
						<span class="text-emerald-400">✓</span>
						<span class="text-sm">Startup Founder: Experiência com produto do zero até cliente pagante</span>
					</div>
					<div class="flex gap-2">
						<span class="text-emerald-400">✓</span>
						<span class="text-sm">Performance obsessed: Otimização é prioridade em tudo que faço</span>
					</div>
				</div>
			</div>
			<h1 class="text-white text-2xl font-semibold mt-10">
				.Experiência Profissional
