---
import "../../global.css";
---

<html lang="pt-br">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Autoatendimento ao Cliente | Kayky Zioti</title>
		<link
			rel="stylesheet"
			href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined"
		/>
	</head>
	<body class="bg-neutral-800 min-h-screen text-white px-6 py-10">
		<main class="max-w-4xl mx-auto">
			<a href="/" class="text-neutral-400 hover:text-white transition-colors flex items-center gap-2 mb-8">
				<span class="material-symbols-outlined text-[18px]">arrow_back_ios</span>
				Voltar para início
			</a>

			<section class="border border-neutral-700 rounded-xl p-6 md:p-8 bg-neutral-800/70">
				<p class="text-sm uppercase tracking-widest text-neutral-400">Projeto Principal</p>
				<h1 class="text-3xl md:text-4xl font-bold mt-2">Autoatendimento ao Cliente</h1>
				<p class="text-neutral-300 mt-4 leading-relaxed">
					Chatbot para WhatsApp que responde dúvidas, apresenta serviços e valores, classifica leads e integra dados com CRM.
				</p>

				<div class="mt-6 inline-flex bg-emerald-700/30 text-emerald-300 px-3 py-1 rounded-full text-sm border border-emerald-700/40">
					Em Produção
				</div>

				<div class="mt-8">
					<h2 class="text-lg font-semibold">Stack principal</h2>
					<div class="flex flex-wrap gap-2 mt-3">
						<span class="text-xs bg-neutral-700 px-3 py-1 rounded-full">TypeScript</span>
						<span class="text-xs bg-neutral-700 px-3 py-1 rounded-full">Express.js</span>
						<span class="text-xs bg-neutral-700 px-3 py-1 rounded-full">Next.js</span>
						<span class="text-xs bg-neutral-700 px-3 py-1 rounded-full">OpenAI API</span>
						<span class="text-xs bg-neutral-700 px-3 py-1 rounded-full">Supabase</span>
						<span class="text-xs bg-neutral-700 px-3 py-1 rounded-full">WhatsApp</span>
					</div>
				</div>
			</section>
		</main>
	</body>
</html>
